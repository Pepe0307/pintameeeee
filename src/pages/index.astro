---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { supabase } from '../lib/supabase';
import { SITE_CONFIG } from '../utils/config';

const { data: featuredProducts, error } = supabase 
  ? await supabase.from('products').select('*').eq('featured', true)
  : { data: null, error: new Error('Supabase client not initialized') };

if (error) {
  console.error('Fetch error:', error.message);
}

const productsToDisplay = featuredProducts || [];
---

<BaseLayout 
  title="Inicio"
  description={`${SITE_CONFIG.siteName} - Descubre y compra obras de arte únicas, hechas a mano y pintadas a mano por Lida. Explora su colección exclusiva desde Colombia.`}
>
  <!-- Hero Section -->
  <section class="relative h-[55vh] flex items-center justify-center bg-gallery-pinpin">
    <div class="relative z-10 text-center text-white px-4 max-w-4xl">
      <h1 class="font-display text-5xl md:text-7xl font-bold mb-6 text-gallery-bone">
        Conoce el mundo de <span class="text-gallery-newpink">Píntame</span>
      </h1>
      <p class="text-xl md:text-2xl mb-8 text-gallery-bone">
        ★ Te damos la bienvenida a nuestra tienda virtual, aquí encontraras todas las piezas de arte disponibles ★
      </p>
      <a href="/catalogo" class="btn-primary text-lg">
        Explorar catálogo
      </a>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="py-20 px-4 bg-gallery-pinkpink">
    <div class="container mx-auto">
      <div class="text-center mb-12">
        <h2 class="font-display text-4xl font-bold text-gallery-charcoal mb-4">
          ☆ Best seller ☆
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Piezas que acompañan tu día a día y reflejan tu estilo
        </p>
      </div>
      
      {productsToDisplay.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {productsToDisplay.map(product => (
            <ProductCard 
              slug={product.id.toString()}
              title={product.title}
              artist={product.artist}
              price={product.price}
              currency={product.currency}
              image={product.image_url}
              category={product.category}
              available={product.available}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-12 bg-gray-50 rounded-2xl">
          <p class="text-gray-500">Estamos actualizando nuestra galería. Vuelve pronto.</p>
        </div>
      )}
      
      <div class="text-center mt-12">
        <a href="/catalogo" class="btn-primary">
          Ver catálogo completo →
        </a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-20 px-4 bg-gallery-pinpin">
    <div class="container mx-auto max-w-4xl text-center">
      <h2 class="font-display text-4xl font-bold text-gallery-charcoal mb-6">
        𓇼 Sobre nosotros 𓇼
      </h2>
      <p class="text-lg text-gray-600 leading-relaxed">
        Somos una marca de piezas creativas hechas 100% a mano. Creemos en el poder del arte para conectar contigo y ayudarte a expresar tu estilo de una forma única y auténtica. Cada creación nace con intención, pensada para acompañarte en tu día a día y llenar tus espacios de color y sentido :)
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-20 px-4 bg-gallery-pinkpink">
    <div class="container mx-auto max-w-2xl text-center">
      <h2 class="font-display text-4xl font-bold text-gallery-charcoal mb-6">
        ⁠Hablemos ✿
      </h2>
      <p class="text-gray-600 mb-8">
        ¿Tienes preguntas sobre nuestras piezas? ¿Quieres personalizar alguna? 
        ¡Contáctanos directamente por WhatsApp!
      </p>
      <a 
        href={`https://wa.me/${SITE_CONFIG.whatsappNumber}?text=${encodeURIComponent(SITE_CONFIG.whatsappDefaultMessage)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-whatsapp inline-flex text-lg"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Chatea con Nosotros
      </a>
    </div>
  </section>
</BaseLayout>